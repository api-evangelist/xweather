{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/xweather/refs/heads/main/json-schema/xweather-lightning-strike-schema.json",
  "title": "LightningStrike",
  "description": "LightningStrike schema from Xweather Weather API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Strike identifier."
    },
    "lat": {
      "type": "number",
      "description": "Latitude of the strike."
    },
    "lon": {
      "type": "number",
      "description": "Longitude of the strike."
    },
    "timestamp": {
      "type": "integer",
      "description": "Unix timestamp of the strike."
    },
    "dateTimeISO": {
      "type": "string",
      "format": "date-time"
    },
    "type": {
      "type": "string",
      "description": "Strike type (e.g., CG for cloud-to-ground, IC for intra-cloud)."
    },
    "polarity": {
      "type": "string",
      "enum": [
        "+",
        "-"
      ],
      "description": "Strike polarity (positive or negative)."
    },
    "peakAmpKA": {
      "type": "number",
      "description": "Peak amplitude in kiloamperes."
    },
    "ic": {
      "type": "boolean",
      "description": "Whether the strike was intra-cloud."
    }
  }
}